PORT=5051
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/jobpilot?retryWrites=true&w=majority
JWT_SECRET=<your-32-char-min-access-secret>
JWT_REFRESH_SECRET=<your-32-char-min-refresh-secret>

# Optional — Cloudinary for resume uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Required for AI features
GROQ_API_KEY=gsk_<your-groq-api-key>

# Optional — for URL-based job extraction
TINYFISH_API_KEY=

# Optional — SMTP for email reminders
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email>
SMTP_PASS=<your-app-password>
EMAIL_FROM=JobPilot <<your-email>>
SMTP_SECURE=false

# Optional — Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NODE_ENV=development

FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=30d
AUTH_COOKIE_NAME=jobpilot_refresh

# Rate limiting
API_RATE_LIMIT_WINDOW_MINUTES=15
API_RATE_LIMIT_MAX=250
AUTH_RATE_LIMIT_WINDOW_MINUTES=10
AUTH_RATE_LIMIT_MAX=12
AI_RATE_LIMIT_WINDOW_MINUTES=1
AI_RATE_LIMIT_MAX=10

# Reminders
DEFAULT_TIMEZONE=UTC
DEFAULT_REMINDER_HOUR=9
REMINDER_CRON=*/10 * * * *
REMINDER_SWEEP_SECRET=
REMINDER_RETRY_LIMIT=3
REMINDER_RETRY_BASE_MINUTES=10
REMINDER_LOCK_MINUTES=20
REMINDER_BATCH_SIZE=25
